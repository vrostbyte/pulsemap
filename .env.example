# PulseMap Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
#
# In dev mode without these keys, each fetcher falls back to mock data
# so the app remains fully functional for local development.

# ─── AirNow API (EPA air quality observations) ──────────────────────────────
# Free key from: https://docs.airnowapi.org/account/request/
# Used by: api/epa-airquality.ts
AIRNOW_API_KEY=

# ─── Upstash Redis (optional — rate-limit cache for edge functions) ───────────
# Free tier at: https://upstash.com/
# If omitted, edge functions skip caching and hit upstream APIs directly.
# Used by: api/*.ts (shared cache layer, not implemented in MVP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
